---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { links } from '../config/links';
import { product } from '../config/product';
---

<BaseLayout
  title={`Download and Setup — ${product.name} | ${product.studioName}`}
  description={`${product.name} download and setup guidance: current access, Windows direct ZIP expectations, manual setup, and support.`}
>
  <div class="site-shell">
    <Navbar />

    <main class="companion-page">
      <section class="section page-top-safe">
        <div class="container companion-split">
          <div>
            <p class="eyebrow">Download and setup</p>
            <h1>Download and setup guidance for the current release.</h1>
            <p class="lead">
              Current public access is handled through the product page and storefront. The public trial build is not available yet; setup guidance is available before purchase.
            </p>
            <div class="cta-row">
              <a href={links.productPage} class="btn btn-primary">View product page</a>
              <a href={links.checkout.href} class="btn btn-secondary">Buy lifetime license</a>
              <a href={links.supportDownload} class="btn btn-secondary">Contact support</a>
            </div>
          </div>

          <article class="release-status-panel">
            <span class="badge">Current release access</span>
            <h2>Trial build availability</h2>
            <p>{product.trial.zipStatus}</p>
            <p>{product.offer.publicPurchaseFlow}</p>
          </article>
        </div>
      </section>

      <section class="section alt">
        <div class="container grid-3">
          <article class="card">
            <h3>{product.release.distribution}</h3>
            <p>The release path is direct and practical, with setup notes visible before purchase.</p>
          </article>
          <article class="card">
            <h3>Unsigned release</h3>
            <p>{product.release.unsignedNote}</p>
          </article>
          <article class="card">
            <h3>Manual app management</h3>
            <p>{product.release.install}, {product.release.update}, and {product.release.uninstall}.</p>
          </article>
          <article class="card">
            <h3>Image workflows</h3>
            <p>{product.workflows.image}</p>
          </article>
          <article class="card">
            <h3>Video workflows</h3>
            <p>{product.workflows.video}</p>
          </article>
          <article class="card">
            <h3>Purchase path</h3>
            <p>Purchase through Lemon Squeezy after reviewing the setup notes and confirming the current release fits your workflow.</p>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
