---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Support — EDITH Dev Studio"
  description="Get support information for Upscaler Studio and contact EDITH Dev Studio for product questions and release-related updates."
>
  <div class="site-shell">
    <Navbar />

    <main>
      <section class="section page-top-safe">
        <div class="container">
          <div class="section-head">
            <p class="eyebrow">Support</p>
            <h1>Support</h1>
            <p class="lead">
              This page is the support entry point for Upscaler Studio and future products from EDITH Dev Studio.
            </p>
          </div>

          <div class="grid-3">
            <article class="card">
              <h3>General contact</h3>
              <p style="margin-top: .75rem;">
                For general product questions and release-related updates, contact
                <a href="mailto:hello@edithdevstudio.com">hello@edithdevstudio.com</a>.
              </p>
            </article>

            <article class="card">
              <h3>Before reaching out</h3>
              <p style="margin-top: .75rem;">
                When support resources expand, this section should help users check system requirements, installation steps, release notes, and common troubleshooting items first.
              </p>
            </article>

            <article class="card">
              <h3>What will be added</h3>
              <p style="margin-top: .75rem;">
                Future support material can include FAQs, activation help, known issues, installation guidance, and links to changelog or release notes.
              </p>
            </article>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
