---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Support — Upscaler Studio | EDITH Dev Studio"
  description="Get support for Upscaler Studio by EDITH Dev Studio."
>
  <Navbar />

  <section class="legal-page">
    <div class="container narrow">
      <p class="eyebrow">Support</p>
      <h1>Support</h1>
      <p class="legal-note">
        This page should evolve into the main customer support surface for Upscaler Studio.
      </p>

      <section class="legal-block premium-panel">
        <h2>What users should find here</h2>
        <p>
          Support contact details, troubleshooting guidance, installation help, license assistance,
          and release-specific notes should be centralized here.
        </p>
      </section>

      <section class="legal-block premium-panel">
        <h2>Recommended future sections</h2>
        <p>
          Add a support email, FAQ, system requirements, known issues, activation help, refund guidance,
          and links to changelog or release notes.
        </p>
      </section>

      <section class="legal-block premium-panel">
        <h2>Current status</h2>
        <p>
          This is still a structured placeholder page, but it now reflects the intended support role more clearly.
        </p>
      </section>
    </div>
  </section>

  <Footer />
</BaseLayout>
