---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Support — Upscaler Studio" description="Support page for Upscaler Studio.">
  <Header />

  <section class="legal-page">
    <div class="narrow">
      <p class="eyebrow">Support</p>
      <h1>Support structure</h1>
      <p class="hero-copy" style="max-width:860px;">
        This page should become the operational support layer for the product once release blockers are fixed.
      </p>

      <div class="grid-2" style="margin-top:2rem;">
        <article class="card">
          <h2>Recommended content</h2>
          <ul class="checks">
            <li>Support email</li>
            <li>Response policy</li>
            <li>Activation help</li>
            <li>Download/install troubleshooting</li>
            <li>Log export instructions</li>
          </ul>
        </article>

        <article class="card">
          <h2>Draft contact</h2>
          <p class="copy" style="margin-top:1rem;">hello@edithdevstudio.com</p>
          <p class="copy">Replace with the real support address before publication.</p>
        </article>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
