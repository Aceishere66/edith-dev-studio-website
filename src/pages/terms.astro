---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Terms of Service | EDITH Dev Studio" description="Read the terms of service for EDITH Dev Studio and Upscaler Studio.">
  <Header />

  <section class="legal-page">
    <div class="narrow">
      <p class="eyebrow">Legal</p>
      <h1>Terms of Service</h1>
      <p class="hero-copy" style="max-width:860px;">
        Current public product terms are summarized here for clarity. Final legal review is still required.
      </p>

      <div class="legal-stack">
        <section class="legal-block">
          <h2>1. Product scope</h2>
          <p>Upscaler Studio is software licensed to the user under the final commercial terms of the published release.</p>
        </section>
        <section class="legal-block">
          <h2>2. License model</h2>
          <p>The current public purchase path is a EUR 30 lifetime license. Trial access is not public yet.</p>
        </section>
        <section class="legal-block">
          <h2>3. Payments and refunds</h2>
          <p>Purchases are routed through the EDITH Dev Studio Lemon Squeezy storefront. Current public copy states no refund after purchase; this wording needs professional legal review.</p>
        </section>
        <section class="legal-block">
          <h2>4. Third-party components</h2>
          <p>Do not claim exclusive rights over bundled third-party components where their own licenses apply.</p>
        </section>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

