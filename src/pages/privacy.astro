---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { links } from '../config/links';
import { product } from '../config/product';
---

<BaseLayout title="Privacy Policy | EDITH Dev Studio" description="Read the privacy policy for EDITH Dev Studio and Upscaler Studio.">
  <Header />

  <section class="legal-page">
    <div class="narrow">
      <p class="eyebrow">Legal</p>
      <h1>Privacy Policy</h1>
      <p class="hero-copy" style="max-width:860px;">
        EDITH Dev Studio keeps the published website lightweight and uses direct support contact for privacy requests.
      </p>

      <div class="legal-stack">
        <section class="legal-block">
          <h2>1. Privacy contact</h2>
          <p>For support or privacy requests, contact <a href={`mailto:${product.support.email}`}>{product.support.email}</a>.</p>
        </section>
        <section class="legal-block">
          <h2>2. Website data</h2>
          <p>The current website is a static Astro site. It does not include account registration, newsletter forms, analytics scripts, tracking embeds, or customer support forms in the site code.</p>
        </section>
        <section class="legal-block">
          <h2>3. Support contact</h2>
          <p>If you email support, EDITH Dev Studio uses the information you provide to answer license, setup, release, and privacy questions.</p>
        </section>
        <section class="legal-block">
          <h2>4. Storefront and payments</h2>
          <p>Purchases are handled through the EDITH Dev Studio Lemon Squeezy storefront. Information entered during checkout is handled through that storefront flow.</p>
          <p><a href={links.checkout.href}>Open the Lemon Squeezy storefront</a></p>
        </section>
        <section class="legal-block">
          <h2>5. Updates</h2>
          <p>If analytics, forms, or embedded services are added later, this page must be updated before those tools are enabled on the public site.</p>
        </section>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

