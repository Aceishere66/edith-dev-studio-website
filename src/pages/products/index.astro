---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Products | EDITH Dev Studio"
  description="Explore products by EDITH Dev Studio, including Upscaler Studio."
>
  <Navbar />

  <section class="legal-page">
    <div class="container narrow">
      <p class="eyebrow">Products</p>
      <h1>Products</h1>
      <p class="legal-note">
        EDITH Dev Studio is being structured as a product studio. Upscaler Studio is the first product in the ecosystem.
      </p>

      <div class="cards two">
        <article class="card premium-panel">
          <h2>Upscaler Studio</h2>
          <p>
            Local AI upscaling for Windows with a premium desktop-product direction focused on image and video workflows.
          </p>
          <a class="btn btn-primary" href="/products/upscaler-studio">Open product page</a>
        </article>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
