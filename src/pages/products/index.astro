---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import AssetPlaceholder from '../../components/AssetPlaceholder.astro';
import { links } from '../../config/links';
import { product } from '../../config/product';
---

<BaseLayout
  title={`Products — ${product.studioName}`}
  description={`Explore products from ${product.studioName}. ${product.name} is the flagship product: ${product.headline}`}
>
  <div class="site-shell">
    <Navbar />

    <main class="companion-page">
      <section class="section page-top-safe companion-hero">
        <div class="container companion-split">
          <div>
            <p class="eyebrow">Products</p>
            <h1>Focused creative software under one studio brand.</h1>
            <p class="lead">
              {product.studioName} is the publisher. {product.name} is the flagship product and the current path into the studio's local-first Windows software direction.
            </p>
            <div class="cta-row">
              <a href={links.productPage} class="btn btn-primary">View Upscaler Studio</a>
              <a href={links.checkout.href} class="btn btn-secondary">Buy lifetime license</a>
            </div>
          </div>

          <AssetPlaceholder variant="mockup" />
        </div>
      </section>

      <section class="section alt">
        <div class="container product-index-feature">
          <div>
            <p class="eyebrow">Flagship</p>
            <h2>{product.name}</h2>
            <p class="lead">
              {product.headline} Built for creators, photographers, Windows users, local-first AI power users, restoration work, image enhancement, and video editors who can install FFmpeg.
            </p>
          </div>

          <div class="product-index-facts">
            <article>
              <span>Offer</span>
              <strong>{product.offer.label}</strong>
              <p>{product.offer.publicPurchaseFlow}</p>
            </article>
            <article>
              <span>Images</span>
              <strong>Ready</strong>
              <p>{product.workflows.image}</p>
            </article>
            <article>
              <span>Video</span>
              <strong>FFmpeg</strong>
              <p>{product.workflows.video}</p>
            </article>
            <article>
              <span>Release</span>
              <strong>{product.release.path}</strong>
              <p>{product.release.distribution}; unsigned and manual.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container companion-split">
          <div>
            <p class="eyebrow">Catalogue direction</p>
            <h2>More products can come later. The current focus stays clear.</h2>
            <p class="lead">
              The products index should feel intentional, not empty. Future tools can live under EDITH Dev Studio, but the current customer journey should point directly to Upscaler Studio.
            </p>
          </div>

          <div class="companion-card-stack">
            <article class="card">
              <h3>Current product</h3>
              <p>{product.name} is the only product being actively sold from the site today.</p>
            </article>
            <article class="card">
              <h3>Future products</h3>
              <p>New Windows-first creative tools can be added here when they have real product pages and release facts.</p>
            </article>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
