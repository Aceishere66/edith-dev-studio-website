---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Upscaler Studio — Product" description="Product page for Upscaler Studio by EDITH Dev Studio.">
  <Header />

  <section class="hero">
    <div class="orb one"></div>
    <div class="orb two"></div>
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Product page</p>
        <h1>Upscaler Studio</h1>
        <p class="hero-copy">
          Position Upscaler Studio as a premium local AI upscaling desktop tool for Windows, focused on image and video workflows,
          batch processing, compare/history visibility, and stronger runtime control.
        </p>
        <div class="cta-row">
          <a class="btn btn-primary" href="/download">Download trial</a>
          <a class="btn btn-secondary" href="/pricing">Buy license</a>
        </div>
      </div>

      <div class="hero-card float-panel">
        <div class="window-dots"><span></span><span></span><span></span></div>
        <div class="preview-grid">
          <div class="preview-box input">Queue input</div>
          <div class="process-card">
            <strong>Batch execution</strong>
            <p class="muted">Recommended model, status tracking, compare flow.</p>
            <div class="progress"><i></i></div>
          </div>
          <div class="preview-box output">Review export</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What to communicate</p>
        <h2>The product story should stay disciplined.</h2>
      </div>
      <div class="grid-2">
        <article class="card">
          <h3>Core positioning</h3>
          <ul class="checks">
            <li>Local AI upscaling for Windows</li>
            <li>Image and video workflows</li>
            <li>Batch, compare, history, control</li>
            <li>Premium desktop UX direction</li>
          </ul>
        </article>
        <article class="card">
          <h3>Avoid overclaiming</h3>
          <ul class="checks">
            <li>Do not promise final compliance until release gates are closed</li>
            <li>Do not promise enterprise guarantees you do not yet support</li>
            <li>Keep legal and support details honest and explicit</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Feature framing</p>
        <h2>What the site should highlight first</h2>
      </div>
      <div class="grid-3">
        <article class="card"><h3>Quality workflow</h3><p>Lead with output quality, repeatability, and control.</p></article>
        <article class="card"><h3>Desktop trust</h3><p>Lean into local processing, inspectability, and user ownership.</p></article>
        <article class="card"><h3>Professional usability</h3><p>Show that the product is guided and premium, not just technical.</p></article>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
