---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { links } from '../config/links';
import { product } from '../config/product';
---

<BaseLayout
  title={`Pricing — ${product.name} | ${product.studioName}`}
  description={`${product.name} pricing: ${product.offer.label}, public purchase through Lemon Squeezy, with setup notes before purchase.`}
>
  <div class="site-shell">
    <Navbar />

    <main class="companion-page">
      <section class="section page-top-safe">
        <div class="container companion-split">
          <div>
            <p class="eyebrow">Pricing</p>
            <h1>{product.offer.label} for {product.name}.</h1>
            <p class="lead">
              The pricing page is a lightweight companion. The product page remains the canonical source for release notes, setup requirements, limitations, and support paths.
            </p>
            <div class="cta-row">
              <a href={links.checkout.href} class="btn btn-primary">Buy lifetime license</a>
              <a href={links.productPricing} class="btn btn-secondary">View full product details</a>
            </div>
          </div>

          <article class="price-card featured companion-price">
            <span class="badge">Active public offer</span>
            <h2>{product.name}</h2>
            <div class="price">{product.offer.price}</div>
            <p class="muted">{product.offer.term} license. {product.offer.refundPolicy}.</p>
            <ul class="price-list">
              <li>{product.workflows.image}</li>
              <li>{product.release.distribution}</li>
              <li>{product.trial.statusLabel}</li>
            </ul>
          </article>
        </div>
      </section>

      <section class="section alt">
        <div class="container grid-3">
          <article class="card">
            <h3>Before buying</h3>
            <p>Review the unsigned ZIP release, manual app management, and FFmpeg requirement if video workflows matter to you.</p>
          </article>
          <article class="card">
            <h3>Trial status</h3>
            <p>{product.trial.zipStatus} {product.trial.supportCta}</p>
          </article>
          <article class="card">
            <h3>Support path</h3>
            <p>Use support for license access, setup questions, unsigned Windows warnings, and FFmpeg guidance.</p>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
