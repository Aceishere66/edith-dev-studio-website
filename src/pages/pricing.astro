---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Pricing — Upscaler Studio" description="Pricing page for Upscaler Studio.">
  <Header />

  <section class="legal-page">
    <div class="narrow">
      <p class="eyebrow">Pricing</p>
      <h1>Simple launch pricing.</h1>
      <p class="hero-copy" style="max-width:860px;">
        Start with one clear paid plan and one free trial path. That is the strongest commercial strategy for the current product stage.
      </p>

      <div class="pricing-grid" style="margin-top:2rem;">
        <article class="price-card">
          <p class="eyebrow">Trial</p>
          <div class="price">Free</div>
          <p class="copy" style="margin-top:.7rem;">Best for testing image quality, speed, and compatibility before buying.</p>
          <ul class="price-list">
            <li>Evaluation download</li>
            <li>Low-friction onboarding</li>
            <li>Trust-building first step</li>
          </ul>
          <div class="cta-row"><a class="btn btn-secondary" href="/download">Download trial</a></div>
        </article>

        <article class="price-card featured">
          <span class="badge">Best launch option</span>
          <p class="eyebrow">Studio License</p>
          <div class="price">€49</div>
          <p class="copy" style="margin-top:.7rem;">Recommended opening price while the product matures and the brand builds trust.</p>
          <ul class="price-list">
            <li>1 PC license</li>
            <li>Full export workflow</li>
            <li>Future upgrade path possible</li>
          </ul>
          <div class="cta-row"><a class="btn btn-primary" href="#">Buy with Lemon Squeezy</a></div>
        </article>
      </div>

      <div class="warning-card" style="margin-top:1.5rem;">
        <strong>Publication note:</strong>
        checkout links, refund wording, upgrade policy, and support terms still need real release-ready values before going live.
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
