---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import PricingPreview from '../components/PricingPreview.astro';
import DownloadPanel from '../components/DownloadPanel.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="EDITH Dev Studio — Premium Windows-first desktop tools"
  description="EDITH Dev Studio is building premium Windows-first desktop software. Discover Upscaler Studio, our featured local-first AI upscaling product."
>
  <div class="site-shell">
    <Navbar />

    <main>
      <Hero />
      <TrustStrip />

      <section class="section">
        <div class="container">
          <div class="section-head">
            <p class="eyebrow">Featured product</p>
            <h2>One publisher. One flagship product. A clear direction.</h2>
            <p class="lead">
              EDITH Dev Studio is the publisher brand. Upscaler Studio is the first featured product: a local-first Windows desktop tool designed for serious image and video upscaling workflows.
            </p>
          </div>

          <div class="product-band product-band-home">
            <div class="grid-2">
              <div>
                <h3>Why the structure matters</h3>
                <p class="muted" style="margin-top: .75rem;">
                  Keeping publisher and product distinct makes the site easier to scale, easier to understand, and more credible for future launches.
                </p>

                <ul class="checks">
                  <li>EDITH Dev Studio stays the umbrella brand</li>
                  <li>Upscaler Studio gets a dedicated product surface</li>
                  <li>The homepage stays focused on hierarchy and clarity</li>
                </ul>
              </div>

              <div>
                <h3>Why Upscaler Studio leads</h3>
                <p class="muted" style="margin-top: .75rem;">
                  The first product page should quickly explain local-first value, workflow seriousness, and the intended launch model without overclaiming availability.
                </p>

                <div class="cta-row" style="margin-top: 1.25rem;">
                  <a href="/products/upscaler-studio" class="btn btn-primary">View product</a>
                  <a href="/about" class="btn btn-secondary">About the studio</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <FeatureGrid />
      <PricingPreview />
      <DownloadPanel />

      <section class="section alt">
        <div class="container">
          <div class="section-head">
            <p class="eyebrow">Studio direction</p>
            <h2>Designed as a product site first, not a throwaway landing page.</h2>
            <p class="lead">
              The current goal is a premium foundation: stronger hierarchy, clearer messaging, and a more serious surface for future screenshots, legal pages, support, and checkout integration.
            </p>
          </div>

          <div class="grid-3">
            <article class="card">
              <h3>Stronger hierarchy</h3>
              <p style="margin-top: .7rem;">The homepage should explain the publisher, the featured product, and the local-first value proposition in seconds.</p>
            </article>

            <article class="card">
              <h3>More credible product framing</h3>
              <p style="margin-top: .7rem;">Upscaler Studio should feel like a serious product page now, even before final screenshots and commercial integrations arrive.</p>
            </article>

            <article class="card">
              <h3>Ready for the next pass</h3>
              <p style="margin-top: .7rem;">Once release gates are closed, the next layer is final copy, legal refinement, support contact polish, and checkout activation.</p>
            </article>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
