---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About EDITH Dev Studio" description="Learn more about EDITH Dev Studio and its premium Windows-first desktop tools.">
  <Header />

  <section class="legal-page">
    <div class="narrow">
      <p class="eyebrow">About</p>
      <h1>EDITH Dev Studio</h1>
      <p class="hero-copy" style="max-width:860px;">
        EDITH Dev Studio is the publisher brand for Upscaler Studio and future premium Windows-first desktop products.
      </p>

      <div class="grid-2" style="margin-top:2rem;">
        <article class="card">
          <h2>Studio role</h2>
          <p class="copy" style="margin-top:1rem;">
            Keep the studio identity broader than a single app so the website can grow into a multi-product hub.
          </p>
        </article>
        <article class="card">
          <h2>Current flagship</h2>
          <p class="copy" style="margin-top:1rem;">
            Upscaler Studio is the current lead product and should occupy the main conversion path of the site.
          </p>
        </article>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

