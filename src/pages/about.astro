---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { product } from '../config/product';
---

<BaseLayout
  title={`About — ${product.studioName}`}
  description={`Learn about ${product.studioName}, the creative software studio behind ${product.name}.`}
>
  <div class="site-shell">
    <Navbar />

    <main>
      <section class="section page-top-safe">
        <div class="container">
          <div class="section-head">
            <p class="eyebrow">About</p>
            <h1>About EDITH Dev Studio</h1>
            <p class="lead">
              {product.studioName} is the creative software studio and publisher behind {product.name}, with a focus on practical local-first Windows tools.
            </p>
          </div>

          <div class="grid-3">
            <article class="card">
              <h3>What the studio is building</h3>
              <p style="margin-top: .75rem;">
                The studio focus is serious desktop software with clear release notes, honest setup expectations, and polished product experiences.
              </p>
            </article>

            <article class="card">
              <h3>Current focus</h3>
              <p style="margin-top: .75rem;">
                {product.name} is the flagship product: {product.headline} Image workflows work out of the box, while video workflows require FFmpeg.
              </p>
            </article>

            <article class="card">
              <h3>Future focus</h3>
              <p style="margin-top: .75rem;">
                The website and studio identity are designed to support multiple products over time, not only a single release.
              </p>
            </article>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
