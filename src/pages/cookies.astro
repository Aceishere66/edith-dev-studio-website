---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Cookie Policy — EDITH Dev Studio" description="Cookie policy draft for EDITH Dev Studio.">
  <Header />

  <section class="legal-page">
    <div class="narrow">
      <p class="eyebrow">Legal</p>
      <h1>Cookie Policy</h1>
      <p class="hero-copy" style="max-width:860px;">
        Keep this page honest: describe only the cookies and tracking technologies actually used by the published site.
      </p>

      <div class="legal-stack">
        <section class="legal-block">
          <h2>1. Technical cookies</h2>
          <p>Describe any strictly necessary cookies if they are present.</p>
        </section>
        <section class="legal-block">
          <h2>2. Analytics</h2>
          <p>If analytics are introduced later, update this page and the consent logic accordingly.</p>
        </section>
        <section class="legal-block">
          <h2>3. Third-party services</h2>
          <p>Only list third-party services that are actually active on the site.</p>
        </section>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
