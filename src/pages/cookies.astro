---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Cookie Policy | EDITH Dev Studio" description="Read the cookie policy for EDITH Dev Studio and Upscaler Studio.">
  <Header />

  <section class="legal-page">
    <div class="narrow">
      <p class="eyebrow">Legal</p>
      <h1>Cookie Policy</h1>
      <p class="hero-copy" style="max-width:860px;">
        The current EDITH Dev Studio website is published without analytics, marketing trackers, or cookie-setting code in the repository.
      </p>

      <div class="legal-stack">
        <section class="legal-block">
          <h2>1. Cookies set by this website</h2>
          <p>The current website code does not intentionally set first-party cookies.</p>
        </section>
        <section class="legal-block">
          <h2>2. Analytics and marketing</h2>
          <p>No analytics scripts, advertising pixels, newsletter forms, or tracking embeds are present in the current site implementation.</p>
        </section>
        <section class="legal-block">
          <h2>3. Third-party services</h2>
          <p>Storefront and social links open external websites. Those services may use their own cookies or tracking technologies after you leave edithdevstudio.com.</p>
        </section>
        <section class="legal-block">
          <h2>4. Future changes</h2>
          <p>Any future analytics, forms, embeds, or marketing cookies must be reflected here before they are enabled on the public site.</p>
        </section>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

