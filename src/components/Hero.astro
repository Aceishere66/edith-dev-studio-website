---
import { links } from "../config/links";
import { product } from "../config/product";
---

<section class="hero home-hero">
  <div class="home-hero-field" aria-hidden="true"></div>

  <div class="container home-hero-grid">
    <div class="home-hero-copy">
      <p class="eyebrow">{product.studioName} · Creative software publisher</p>
      <h1>Focused creative software for local-first visual work.</h1>
      <p class="hero-copy">
        {product.studioName} builds precise Windows-first tools for creators who want control, clarity, and practical AI workflows. {product.name} is the flagship product: {product.headline}
      </p>

      <div class="cta-row">
        <a href={links.productPage} class="btn btn-primary">View product</a>
        <a href={links.checkout.href} class="btn btn-secondary">Buy lifetime license</a>
      </div>

      <p class="support-note">
        Active public purchase path: {product.offer.label} through the EDITH Dev Studio storefront. {product.trial.statusLabel}
      </p>

      <div class="home-hero-facts" aria-label="Product facts">
        <span>{product.platform}</span>
        <span>{product.release.path}</span>
        <span>{product.release.distribution}</span>
        <span>{product.workflows.videoShort}</span>
      </div>
    </div>

    <div class="home-hero-visual" aria-label={`${product.name} abstract product preview`}>
      <div class="home-product-frame">
        <div class="home-frame-top">
          <span></span>
          <span></span>
          <span></span>
          <strong>{product.name}</strong>
        </div>

        <div class="home-frame-body">
          <div class="home-frame-sidebar">
            <span>Local</span>
            <span>Queue</span>
            <span>Export</span>
          </div>

          <div class="home-preview-stack">
            <div class="home-preview-before">
              <small>Original</small>
            </div>
            <div class="home-preview-after">
              <small>Enhanced</small>
            </div>
          </div>
        </div>

        <div class="home-frame-status">
          <div>
            <span class="home-status-dot"></span>
            <strong>Images ready out of the box</strong>
          </div>
          <div>
            <span class="home-status-dot warn"></span>
            <strong>Video requires FFmpeg</strong>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
