---
import { links } from "../config/links";
import { product } from "../config/product";
---

<section class="section">
  <div class="container product-band">
    <div class="grid-2">
      <div>
        <p class="eyebrow">Publisher</p>
        <h2>{product.studioName}</h2>
        <p class="lead">
          The site is structured so {product.name} is the flagship product today, while the studio brand can support future creative tools later.
        </p>
      </div>
      <div>
        <ul class="checks">
          <li>Current canonical product page: <span class="inline-code">{links.productPage}</span></li>
          <li>Current offer: {product.offer.label}</li>
          <li>{product.trial.statusLabel}</li>
          <li>{product.workflows.video}</li>
        </ul>
      </div>
    </div>
  </div>
</section>
