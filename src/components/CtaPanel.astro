---
import { links } from "../config/links";
---

<section class="section">
  <div class="container cta-panel">
    <div>
      <p class="eyebrow">Product truth</p>
      <h2>Review the release notes before checkout.</h2>
      <p class="lead">
        Upscaler Studio is available through the public storefront, but setup limitations and trial ZIP status should be clear before purchase.
      </p>
    </div>
    <div class="cta-stack">
      <a class="btn btn-primary" href={links.productPage}>Open product page</a>
      <a class="btn btn-secondary" href={links.supportPage}>Open support page</a>
    </div>
  </div>
</section>
