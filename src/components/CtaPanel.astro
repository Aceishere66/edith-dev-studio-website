---
import { links } from "../config/links";
---

<section class="section">
  <div class="container cta-panel">
    <div>
      <p class="eyebrow">Release clarity</p>
      <h2>Review the current release before purchase.</h2>
      <p class="lead">
        Upscaler Studio is available through the storefront, with setup requirements and trial build availability explained before checkout.
      </p>
    </div>
    <div class="cta-stack">
      <a class="btn btn-primary" href={links.productPage}>Open product page</a>
      <a class="btn btn-secondary" href={links.supportPage}>Open support page</a>
    </div>
  </div>
</section>
