---
import { links } from "../config/links";
import { product } from "../config/product";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a href={links.home} class="brand" aria-label={`${product.studioName} home`}>
        <span class="brand-mark">E</span>
        <span>
          <small>Publisher</small>
          <strong>{product.studioName}</strong>
        </span>
      </a>

      <p class="muted footer-copy">
        Creative software studio and publisher behind {product.name}, built around local-first Windows workflows and honest product boundaries.
      </p>

      <p class="muted footer-copy">
        Public purchase path: {product.offer.label}. {product.trial.statusLabel}
      </p>
    </div>

    <div>
      <h3>Explore</h3>
      <ul class="footer-list">
        <li><a href={links.products}>Products</a></li>
        <li><a href={links.productPage}>{product.name}</a></li>
        <li><a href="/about">About</a></li>
        <li><a href={links.supportPage}>Support</a></li>
      </ul>
    </div>

    <div>
      <h3>Legal & social</h3>
      <ul class="footer-list">
        <li><a href={links.privacy}>Privacy Policy</a></li>
        <li><a href={links.terms}>Terms of Service</a></li>
        <li><a href={links.cookies}>Cookie Policy</a></li>
        <li><a href={links.instagram.href}>Instagram</a></li>
        <li><a href={links.xTwitter.href}>X / Twitter</a></li>
        <li><span>{product.support.email}</span></li>
      </ul>
    </div>
  </div>
</footer>
