---
import { product } from "../config/product";

const features = [
  {
    title: "Windows desktop workflow",
    body: "A focused product surface with clearer entry points, local control, and direct setup notes."
  },
  {
    title: "Image workflow ready",
    body: product.workflows.image
  },
  {
    title: "Video with FFmpeg",
    body: product.workflows.video
  },
  {
    title: "Direct release facts",
    body: `${product.release.distribution}; unsigned, with manual install, update, and uninstall.`
  },
  {
    title: "Local-first positioning",
    body: "The value proposition stays anchored around creator control and less cloud dependence."
  },
  {
    title: "Honest product limits",
    body: "The site keeps release status, setup requirements, and trial build availability visible before purchase."
  }
];
---

<section class="section alt">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">Why it stands out</p>
      <h2>A real product surface, not a generic AI landing page.</h2>
      <p class="lead">
        Upscaler Studio pairs AI upscaling with a clear Windows workflow, visible setup requirements, and direct purchase terms.
      </p>
    </div>

    <div class="grid-3">
      {features.map((feature) => (
        <article class="card">
          <h3>{feature.title}</h3>
          <p>{feature.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
