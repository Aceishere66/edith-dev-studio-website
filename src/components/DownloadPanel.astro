---
import { links } from "../config/links";
import { product } from "../config/product";
---

<section class="section alt">
  <div class="container">
    <div class="cta-panel release-panel">
      <div>
        <p class="eyebrow">Release path</p>
        <h2>Direct ZIP release. Public trial ZIP not available yet.</h2>
        <p class="lead">
          The product story should stay commercially clear without pretending that a public trial download exists. Setup and download guidance route through the product page and support.
        </p>
      </div>

      <div class="cta-stack">
        <a href={links.productPage} class="btn btn-primary">View product page</a>
        <a href={links.supportDownload} class="btn btn-secondary">Download guidance</a>
      </div>
    </div>
  </div>
</section>
