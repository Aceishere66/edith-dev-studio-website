---
import { product } from "../config/product";
---

<section class="section" id="faq">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">FAQ</p>
      <h2>Key questions for the current release</h2>
      <p class="lead">Short answers for purchase, setup, and support decisions.</p>
    </div>

    <div class="faq-grid">
      <article class="faq-item">
        <h3>Is checkout live?</h3>
        <p>The public purchase path is the {product.offer.label} license through Lemon Squeezy.</p>
      </article>
      <article class="faq-item">
        <h3>Is a public trial build available?</h3>
        <p>{product.trial.statusLabel} {product.trial.supportCta}</p>
      </article>
      <article class="faq-item">
        <h3>Does video require extra setup?</h3>
        <p>{product.workflows.video}</p>
      </article>
      <article class="faq-item">
        <h3>Is the legal content final?</h3>
        <p>Legal-sensitive wording still needs professional review before purchase traffic increases.</p>
      </article>
    </div>
  </div>
</section>
