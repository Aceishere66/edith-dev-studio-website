---
import { links } from "../config/links";
import { product } from "../config/product";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const navItems = [
  { href: links.home, label: "Home" },
  { href: links.products, label: "Products" },
  { href: links.productPage, label: product.name },
  { href: links.supportPage, label: "Support" },
  { href: "/about", label: "About" }
];

const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return currentPath === normalized;
};
---

<header class="site-header">
  <div class="container nav">
    <a href={links.home} class="brand" aria-label={`${product.studioName} home`}>
      <span class="brand-mark">E</span>
      <span>
        <small>Publisher</small>
        <strong>{product.studioName}</strong>
      </span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`nav-link${isActive(item.href) ? " is-active" : ""}`}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
      <a href={links.productPage} class="btn btn-secondary nav-cta">View product</a>
    </nav>
  </div>
</header>
