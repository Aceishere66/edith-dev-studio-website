---
import { links } from "../config/links";
import { product } from "../config/product";
---

<section class="section">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">Offer</p>
      <h2>{product.offer.label} with setup notes up front.</h2>
      <p class="lead">
        The public purchase path is the lifetime license. Trial build access is not available yet, so setup and release requirements are visible before purchase.
      </p>
    </div>

    <div class="pricing-grid">
      <article class="price-card featured">
        <span class="badge">Active public offer</span>
        <h3>{product.name}</h3>
        <div class="price">{product.offer.price}</div>
        <p class="muted">{product.offer.term} license. {product.offer.refundPolicy}.</p>

        <ul class="price-list">
          <li>{product.workflows.image}</li>
          <li>{product.release.distribution}</li>
          <li>{product.release.path}</li>
        </ul>

        <a href={links.checkout.href} class="btn btn-primary">Buy lifetime license</a>
      </article>

      <article class="price-card">
        <span class="badge">Before purchase</span>
        <h3>Know the setup path</h3>
        <div class="price">ZIP</div>
        <p class="muted">{product.trial.statusLabel} {product.workflows.video}</p>

        <ul class="price-list">
          <li>{product.release.unsignedNote}</li>
          <li>{product.release.install}, {product.release.update}, and {product.release.uninstall}</li>
          <li>{product.trial.zipStatus}</li>
        </ul>

        <a href={links.setupNotes} class="btn btn-secondary">Read setup notes</a>
      </article>
    </div>
  </div>
</section>
